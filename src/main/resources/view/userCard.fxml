<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="350.0" prefWidth="213.0" xmlns="http://javafx.com/javafx/22-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.librarysystem.controller.AccountCardController" stylesheets="@../css/admin.css">
    <center>
        <VBox alignment="CENTER" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #dcdcdc; -fx-border-width: 1; -fx-border-radius: 10; -fx-padding: 20;">
            <!-- Image for the user -->
            <ImageView fx:id="userImage" fitHeight="100.0" fitWidth="100.0" preserveRatio="true">
                <image>
                    <Image url="@../images/profile.png" />
                </image>
            </ImageView>

            <!-- User details -->
            <Label fx:id="accountId" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
            <Label fx:id="userName" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #343a40;" />
            <Label fx:id="role" style="-fx-font-size: 16px; -fx-text-fill: #007bff;" />

            <!-- Buttons -->
            <Button fx:id="viewDetailsButton" text="View Details" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5;" />
            <Button fx:id="deleteUser" text="Delete" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5;" />
        </VBox>
    </center>
</BorderPane>
