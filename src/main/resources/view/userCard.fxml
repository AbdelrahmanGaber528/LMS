<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="30.0" prefWidth="185.0" xmlns="http://javafx.com/javafx/22-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.librarysystem.controller.AccountCardController">
    <center>
        <VBox alignment="CENTER" prefHeight="350.0" prefWidth="213.0" spacing="15" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 10;">
            <!-- Image for the book -->
            <ImageView fx:id="userImage" fitHeight="100.0" fitWidth="80.0" preserveRatio="true" />

            <!-- Book details -->
            <Label fx:id="accountId" style="-fx-font-size: 17px;" />
            <Label fx:id="userName" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
            <Label fx:id="role" style="-fx-font-size: 14px;" />

            <!-- Button for details -->
            <Button fx:id="viewDetailsButton" text="View Details" />
            <Button fx:id="deleteUser" text="Delete"/>
        </VBox>
    </center>
</BorderPane>
