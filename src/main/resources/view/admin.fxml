<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<AnchorPane xmlns="http://javafx.com/javafx/22-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.librarysystem.controller.AdminController">
    <children>
        <VBox layoutX="10.0" layoutY="10.0" prefHeight="480.0" prefWidth="780.0" spacing="20.0">
            <children>
                <Label text="Admin Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold;" />

                <HBox spacing="15.0">
                    <Button fx:id="manageUsersButton" text="Manage Users" prefWidth="150.0" />
                    <Button fx:id="manageBooksButton" text="Manage Books" prefWidth="150.0" />
                    <Button fx:id="viewReportsButton" text="View Reports" prefWidth="150.0" />
                </HBox>

                <TableView fx:id="dataTable" prefHeight="400.0" prefWidth="760.0">
                    <columns>
                        <TableColumn fx:id="column1" text="Column 1" prefWidth="200.0" />
                        <TableColumn fx:id="column2" text="Column 2" prefWidth="200.0" />
                        <TableColumn fx:id="column3" text="Column 3" prefWidth="200.0" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
