<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/22-ea" xmlns:fx="http://javafx.com/fxml" fx:controller="com.librarysystem.controller.BookCardController">
    <center>
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 10;">
            <Label fx:id="bookTitle" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
            <Label fx:id="bookAuthor" style="-fx-font-size: 14px;" />
            <Label fx:id="bookGenre" style="-fx-font-size: 14px;" />
            <Label fx:id="bookAvailability" style="-fx-font-size: 14px; -fx-text-fill: green;" />
            <Button text="View Details" fx:id="viewDetailsButton" />
        </VBox>
    </center>
</BorderPane>
